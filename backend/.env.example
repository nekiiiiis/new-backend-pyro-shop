# Entorno de ejecución
APP_ENV=development
LOG_LEVEL=info

# Servidor
HOST=0.0.0.0
PORT=3000

# Base de datos (SQLite por defecto). Se puede sustituir por cualquier URL SQLAlchemy
DATABASE_URL=sqlite:///./data/pyroshop.db

# Seguridad JWT
JWT_SECRET=cambia-esta-clave-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# CORS (separado por comas)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Semilla inicial (usuarios y productos demo si la BD está vacía)
SEED_ON_STARTUP=true
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=123456
SEED_USER_USERNAME=usuarioPrueba
SEED_USER_PASSWORD=123456
